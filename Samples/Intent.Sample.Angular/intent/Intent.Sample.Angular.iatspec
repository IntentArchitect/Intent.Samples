<?xml version="1.0" encoding="utf-8"?>
<applicationTemplate type="sample-solution">
  <id>Intent.Sample.Angular</id>
  <version>1.0.2</version>
  <supportedClientVersions>[4.6.0-beta.3, 5.0.0-a)</supportedClientVersions>
  <displayName>Angular Web Application Sample</displayName>
  <coverImageUrl src="data:image/png;base64," />
  <additionalImages>
    <image src="data:image/png;base64," />
    <image src="data:image/png;base64," />
    <image src="data:image/png;base64," />
    <image src="data:image/png;base64," />
  </additionalImages>
  <shortDescription>Angular front-end sample application using Material Components</shortDescription>
  <longDescription>This sample application demonstrates how Intent Architect enables you to visually design user interfaces and automatically generate a fully functional Angular front-end using Material components, connecting to a C# backend service.

It highlights how UI pages, dialogs and page interactions can be modeled within the platform and combined with AI, can be translated into clean, maintainable Angular code—accelerating front-end development and ensuring consistency across your application.</longDescription>
  <priority>0</priority>
  <icon type="UrlImagePath" source="data:image/svg+xml;base64," />
  <allowRenameApplication>false</allowRenameApplication>
  <includeSourceCode>true</includeSourceCode>
  <defaultName>NewApplication</defaultName>
  <relativeOutputLocation />
</applicationTemplate>