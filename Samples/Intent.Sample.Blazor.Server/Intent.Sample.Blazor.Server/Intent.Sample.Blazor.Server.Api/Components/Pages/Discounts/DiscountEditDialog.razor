<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            Edit Discount
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2" Class="pa-2">
            @if (Model == null)
            {
                <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="pa-4">
                    <MudProgressCircular Size="Size.Medium" Indeterminate />
                </MudStack>
            }
            else
            {
                <MudForm @ref="_form">
                    <MudStack Spacing="2">
                        <MudTextField Label="Code"
                                      @bind-Value="Model.Code"
                                      For="@(() => Model.Code)"
                                      Required="true"
                                      Immediate
                                      Variant="Variant.Text" />
                        <MudNumericField T="decimal?" Label="Discount Amount"
                                         @bind-Value="Model.DiscountAmount"
                                         For="@(() => Model.DiscountAmount)"
                                         Required="true"
                                         Immediate />
                        <MudDatePicker Label="Expiry"
                                       @bind-Date="Model.Expiry"
                                       DateFormat="yyyy-MM-dd"
                                       Required="true"
                                       PickerVariant="PickerVariant.Inline" />
                    </MudStack>
                </MudForm>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Secondary" OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="SaveAsync"
                   Disabled="@(_isSaving || Model == null)">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>
