@page "/titles/list"
@using Intent.Sample.Blazor.Server.Application.Titles

<MudPaper Class="pa-4 mb-4 ux-gradient-primary" Elevation="0">
    <MudText Typo="Typo.h4" Class="text-white font-weight-bold mb-2">
        <MudIcon Icon="@Icons.Material.Filled.Book" Class="mr-2" />
        Titles
    </MudText>
    <MudText Typo="Typo.body1" Class="text-white opacity-90">
        Browse the list of titles.
    </MudText>
</MudPaper>

<MudCard Class="ux-fade-in-up" Style="animation-delay: 0.1s">
    <MudCardHeader>
        <CardHeaderContent>
            <MudGrid>
                <MudItem xs="12">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="NavigateToTitleAddPage">
                        Add Title
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Refresh"
                               OnClick="LoadTitles"
                               Class="ml-2">
                        Refresh
                    </MudButton>
                </MudItem>
            </MudGrid>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        @if (TitlesModels is null)
        {
            <MudStack Direction="FlexDirection.Row"
                      AlignItems="AlignItems.Center"
                      Justify="Justify.FlexStart"
                      Spacing="2">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                <MudText Typo="Typo.body2">Loading titles...</MudText>
            </MudStack>
        }
        else if (!TitlesModels.Any())
        {
            <MudText Typo="Typo.body2">No titles found.</MudText>
        }
        else
        {
            <MudTable T="TitleDto"
                      Items="TitlesModels"
                      Dense="true"
                      Hover="true"
                      Striped
                      Elevation="1">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">@context.Name</MudTd>
                    <MudTd DataLabel="Actions">
                        <MudTooltip Text="Edit Title">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Color="Color.Primary"
                                           OnClick="@(() => NavigateToTitleEditPage(context.Id))" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudCardContent>
</MudCard>
