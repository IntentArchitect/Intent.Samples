<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            Edit Brand
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2" Class="pa-4">
            @if (_isLoading || Model == null)
            {
                <MudStack Justify="Justify.Center" AlignItems="AlignItems.Center" Style="min-height:120px">
                    <MudProgressCircular Size="Size.Medium" Indeterminate="true" Color="Color.Primary" />
                </MudStack>
            }
            else
            {
                <MudForm @ref="_form">
                    <MudStack Spacing="2">
                        <MudTextField Label="Name"
                                      @bind-Value="Model.Name"
                                      For="@(() => Model.Name)"
                                      Required="true"
                                      Immediate="true"
                                      Variant="Variant.Text"
                                      Disabled="_isSaving" />
                    </MudStack>
                </MudForm>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Secondary"
                   Variant="Variant.Outlined"
                   OnClick="Cancel"
                   Disabled="_isSaving">
            Cancel
        </MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="SaveAsync"
                   Disabled="_isSaving || Model == null">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>