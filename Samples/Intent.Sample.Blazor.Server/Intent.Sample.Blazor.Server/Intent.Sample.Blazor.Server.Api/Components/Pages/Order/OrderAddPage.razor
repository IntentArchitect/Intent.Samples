@page "/order/add"
@using Intent.Sample.Blazor.Server.Application.Customers
@using Intent.Sample.Blazor.Server.Application.Products

<MudPaper Class="pa-4 mb-4 ux-gradient-primary" Elevation="0">
    <MudText Typo="Typo.h4" Class="text-white font-weight-bold mb-2">
        <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Class="mr-2" />
        Add Order
    </MudText>
    <MudText Typo="Typo.body1" Class="text-white opacity-90">
        Capture a new customer order and its items.
    </MudText>
</MudPaper>

<MudCard Class="ux-fade-in-up" Style="animation-delay: 0.1s">
    <MudCardContent>
        <MudForm @ref="_form" Model="@Model">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudSelect T="Guid?" @bind-Value="Model.CustomerId" Label="Customer" Placeholder="Select customer" Required="true" RequiredError="Customer is required">
                        @if (CustomersModels?.Data != null)
                        {
                            foreach (var c in CustomersModels.Data)
                            {
                                <MudSelectItem T="Guid?" Value="@c.Id">@c.Name @c.Surname (@c.Email)</MudSelectItem>
                            }
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudDatePicker @bind-Date="Model.OrderedDate" Label="Ordered date" Required="true" RequiredError="Order date is required" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="Model.OrderNo"
                                  Label="Order number"
                                  Placeholder="Enter order number"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.ConfirmationNumber"
                                  Immediate="true"
                                  Required="true"
                                  RequiredError="Order number is required" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="Model.DiscountCode"
                                  Label="Discount code"
                                  Placeholder="Enter discount code"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.LocalOffer"
                                  Immediate="true"
                                  Required="true"
                                  RequiredError="Discount code is required" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudNumericField T="decimal?" @bind-Value="Model.Total" Label="Total" ReadOnly="true" Disabled="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Payments" />
                </MudItem>

                <MudItem xs="12">
                    <MudDivider Class="my-4" />
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.h6">Order items</MudText>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="AddOrderItem">Add item</MudButton>
                    </MudStack>
                </MudItem>

                @if (Model.OrderItems != null && Model.OrderItems.Count > 0)
                {
                    @foreach (var t in Model.OrderItems.Select((item, index) => new { item, index }))
                    {
                        <MudItem xs="12" Class="mb-4 pb-3" @key="t.item">
                            <MudGrid GutterSize="3">
                                <MudItem xs="12" md="5">
                                    <MudSelect T="Guid?" @bind-Value="t.item.ProductId" Label="Product" Placeholder="Select product" Required="true" RequiredError="Product is required">
                                        @if (ProductsModels != null)
                                        {
                                            foreach (var p in ProductsModels)
                                            {
                                                <MudSelectItem T="Guid?" Value="@p.Id">@p.Name (@p.Code)</MudSelectItem>
                                            }
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="6" md="3">
                                    <MudNumericField T="int?" 
                                                     Value="t.item.Units" 
                                                     ValueChanged="@(v => { t.item.Units = v; CalculateTotal(); })"
                                                     Label="Units" 
                                                     Placeholder="0" 
                                                     Min="1" 
                                                     Immediate="true" 
                                                     Required="true" 
                                                     RequiredError="Units are required" />
                                </MudItem>
                                <MudItem xs="6" md="3">
                                    <MudNumericField T="decimal?" 
                                                     Value="t.item.Price" 
                                                     ValueChanged="@(v => { t.item.Price = v; CalculateTotal(); })"
                                                     Label="Unit price" 
                                                     Placeholder="0.00" 
                                                     Min="0" 
                                                     Immediate="true" 
                                                     Required="true" 
                                                     RequiredError="Price is required" />
                                </MudItem>
                                <MudItem xs="12" md="1" Class="d-flex align-center justify-end">
                                    <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" OnClick="@(() => RemoveOrderItem(t.index))">Remove</MudButton>
                                </MudItem>
                            </MudGrid>
                        </MudItem>
                    }
                }

                <MudItem xs="12" Class="mt-4">
                    <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center">
                        <MudButton OnClick="SaveAsync"
                                   Disabled="@_saving"
                                   Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   StartIcon="@Icons.Material.Filled.Save">
                            @if (_saving)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Saving…</span>
                            }
                            else
                            {
                                <span>Save</span>
                            }
                        </MudButton>
                        <MudButton OnClick="NavigateToOrderListPage"
                                   Disabled="@_saving"
                                   Color="Color.Secondary"
                                   Variant="Variant.Filled"
                                   StartIcon="@Icons.Material.Filled.ArrowBack">
                            Back to list
                        </MudButton>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudForm>
    </MudCardContent>
</MudCard>
