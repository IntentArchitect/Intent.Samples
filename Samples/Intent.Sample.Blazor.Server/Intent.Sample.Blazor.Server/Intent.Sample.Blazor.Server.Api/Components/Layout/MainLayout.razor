@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar>
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@((e) => DrawerToggle())" />
        <MudButton Href="/"
                   Class="my-2 mr-2"
                   Color="Color.Inherit">
            <MudText Typo="Typo.h5">Blazor Sample</MudText>
        </MudButton>
        <MudSpacer />
        <MudMenu Icon="@Icons.Material.Filled.MoreVert">
            <MudMenuItem Icon="@Icons.Material.Filled.Person">Profile</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.ManageAccounts">My Account</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.Logout">Logout</MudMenuItem>
        </MudMenu>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen"
               ClipMode="DrawerClipMode.Always"
               Elevation="2"
               Class="pt-2">
        <MudNavMenu>
            <MudNavLink Href="/customer/list">Customer Search</MudNavLink>
            <MudNavLink Href="/order/list">Orders</MudNavLink>
            <MudNavLink Href="/brand/list">Brands</MudNavLink>
            <MudNavLink Href="/product/list">Products</MudNavLink>
            <MudNavLink Href="/titles/list">Titles</MudNavLink>
            <MudNavLink Href="/discounts/list">Discounts</MudNavLink>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent Class="mt-16 pa-4">@Body</MudMainContent>
</MudLayout>
