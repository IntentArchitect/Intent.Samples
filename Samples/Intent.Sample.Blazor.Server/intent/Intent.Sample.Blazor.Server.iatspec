<?xml version="1.0" encoding="utf-8"?>
<applicationTemplate type="sample-solution">
  <id>Intent.Sample.Blazor.Server</id>
  <version>1.0.0</version>
  <supportedClientVersions>[4.6.0-beta.3, 5.0.0-a)</supportedClientVersions>
  <displayName>Blazor Server Application - Sample</displayName>
  <coverImageUrl src="data:image/png;base64," />
  <additionalImages>
    <image src="data:image/png;base64," />
    <image src="data:image/png;base64," />
    <image src="data:image/png;base64," />
    <image src="data:image/png;base64," />
  </additionalImages>
  <shortDescription>Blazor Server front-end sample application using MudBlazor components.</shortDescription>
  <longDescription>This sample application demonstrates how **Intent Architect** enables you to visually design user interfaces and automatically generate a fully functional **Blazor Server** front-end using **MudBlazor** components. 

It highlights how UI elements, forms, navigation, and page interactions can be modeled within the platform and translated into clean, maintainable Blazor code - accelerating front-end development and ensuring consistency across your application.</longDescription>
  <priority>0</priority>
  <icon type="UrlImagePath" source="data:image/svg+xml;base64," />
  <allowRenameApplication>false</allowRenameApplication>
  <includeSourceCode>true</includeSourceCode>
  <defaultName>NewApplication</defaultName>
  <relativeOutputLocation />
</applicationTemplate>